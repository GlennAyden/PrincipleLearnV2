{
  "name": "principle-learn",
  "version": "0.2.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "cross-env FAST_REFRESH=false next dev",
    "dev:no-lint": "cross-env FAST_REFRESH=false next dev --no-lint",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/api",
    "test:e2e": "playwright test",
    "test:e2e:user": "playwright test tests/e2e/user",
    "test:e2e:admin": "playwright test tests/e2e/admin",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test:unit && npm run test:e2e",
    "test:ci": "jest --ci --coverage && playwright test",
    "test:api-legacy": "npx ts-node scripts/test-admin-user-api.ts",
    "test:dataflow": "npx ts-node scripts/test-api-endpoints.ts",
    "playwright:install": "playwright install"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.1",
    "@types/bcryptjs": "^2.4.6",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.2.0",
    "jsonwebtoken": "^9.0.2",
    "next": "^15.5.12",
    "openai": "^4.96.0",
    "papaparse": "^5.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.5.0",
    "react-is": "^19.2.4",
    "sass": "^1.87.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcrypt": "^5.0.2",
    "@types/d3-array": "^3.2.2",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^20.17.44",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^7.0.3",
    "d3-array": "^3.2.4",
    "eslint": "^10.0.2",
    "eslint-config-next": "^16.2.2",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "msw": "^2.12.14",
    "node-mocks-http": "^1.17.2",
    "puppeteer": "^24.37.5",
    "recharts": "^3.8.1",
    "supabase": "^2.91.3",
    "ts-jest": "^29.4.6",
    "typescript": "^5"
  }
}
