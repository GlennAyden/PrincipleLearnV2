{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "types": [
            "node",
            "jest"
        ],
        "moduleResolution": "bundler",
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/*"
            ]
        },
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "isolatedModules": true
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "tests/**/*.ts",
        "tests/**/*.tsx",
        "src/global.d.ts"
    ],
    "exclude": [
        "node_modules",
        ".next"
    ]
}